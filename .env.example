# 应用配置
APP_NAME=task-machinery
APP_VERSION=0.1.0

# HTTP服务配置
HTTP_PORT=8080
HTTP_USE_PREFORK_MODE=false

# 日志配置
LOG_LEVEL=debug

# PostgreSQL数据库配置
PG_POOL_MAX=10
PG_URL=postgres://postgres:postgres@localhost:5432/task_machinery?sslmode=disable

# 指标收集配置
METRICS_ENABLED=true

# Swagger文档配置
SWAGGER_ENABLED=true

# Machinery任务队列配置
MACHINERY_REDIS_HOST=localhost
MACHINERY_REDIS_PORT=6379
MACHINERY_REDIS_PASSWORD=
MACHINERY_REDIS_DB=0
MACHINERY_REDIS_KEY=machinery_tasks
MACHINERY_DEFAULT_QUEUE=default_queue